<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>홍익대 봉사동아리 스케줄 매니저</title>
    <style>
        body { font-family: 'Pretendard', sans-serif; background-color: #f0f2f5; color: #1c1e21; display: flex; justify-content: center; padding: 20px; }
        .container { width: 100%; max-width: 900px; background: white; padding: 40px; border-radius: 20px; box-shadow: 0 12px 30px rgba(0,0,0,0.08); }
        h1 { color: #003366; text-align: center; margin-bottom: 30px; font-weight: 800; border-bottom: 3px solid #003366; display: inline-block; width: 100%; padding-bottom: 10px; }
        .input-card { background: #f8f9fa; padding: 25px; border-radius: 15px; margin-bottom: 30px; border: 1px solid #e9ecef; }
        .input-row { display: flex; gap: 15px; flex-wrap: wrap; align-items: center; justify-content: center; }
        label { font-weight: bold; }
        select, input { padding: 10px; border-radius: 8px; border: 1px solid #ddd; background: white; }
        button { padding: 10px 25px; border-radius: 8px; border: none; cursor: pointer; font-weight: bold; transition: all 0.2s; }
        .btn-add { background-color: #003366; color: white; }
        .btn-add:hover { background-color: #002244; transform: translateY(-2px); }
        .btn-calc { background-color: #28a745; color: white; width: 100%; margin-top: 15px; font-size: 1.1rem; }
        .btn-calc:hover { background-color: #218838; }
        #result { margin-top: 25px; padding: 25px; background: #e7f3ff; border-left: 5px solid #003366; border-radius: 10px; font-size: 1.1rem; min-height: 20px; }
        table { width: 100%; border-collapse: collapse; margin-top: 30px; }
        th { background-color: #003366; color: white; padding: 12px; }
        td { border-bottom: 1px solid #eee; padding: 12px; text-align: center; }
    </style>
</head>
<body>

<div class="container">
    <h1>🏛️ 홍익대 봉사동아리 스케줄 최적화 시스템</h1>
    
    <div class="input-card">
        <div class="input-row">
            <div>
                <label>이름:</label>
                <input type="text" id="memberName" placeholder="이름 입력" style="width: 100px;">
            </div>
            
            <div>
                <label>요일:</label>
                <select id="memberDay">
                    <option value="월">월요일</option>
                    <option value="화">화요일</option>
                    <option value="수">수요일</option>
                    <option value="목">목요일</option>
                    <option value="금">금요일</option>
                </select>
            </div>
            
            <div>
                <label>희망 시간대:</label>
                <select id="memberTimeSlot">
                    <option value="9">오전 9시 ~ 오전 10시</option>
                    <option value="10">오전 10시 ~ 오전 11시</option>
                    <option value="11">오전 11시 ~ 오후 12시</option>
                    <option value="12">오후 12시 ~ 오후 1시</option>
                    <option value="13">오후 1시 ~ 오후 2시</option>
                    <option value="14">오후 2시 ~ 오후 3시</option>
                    <option value="15">오후 3시 ~ 오후 4시</option>
                    <option value="16">오후 4시 ~ 오후 5시</option>
                    <option value="17">오후 5시 ~ 오후 6시</option>
                    <option value="18">오후 6시 ~ 오후 7시</option>
                    <option value="19">오후 7시 ~ 오후 8시</option>
                    <option value="20">오후 8시 ~ 오후 9시</option>
                </select>
            </div>
            <button class="btn-add" onclick="addMember()">추가</button>
        </div>
        <button class="btn-calc" onclick="calculate()">최적의 모임 시간 도출하기</button>
    </div>

    <div id="result">💡 부원들의 데이터를 입력하고 분석 버튼을 눌러주세요.</div>

    <table id="memberTable">
        <thead>
            <tr>
                <th>성함</th>
                <th>가능 요일</th>
                <th>선택 시간대</th>
                <th>관리</th>
            </tr>
        </thead>
        <tbody id="memberList">
            </tbody>
    </table>
</div>

<script>
    // 데이터를 담을 배열
    let scheduleData = [];

    // '추가' 버튼 클릭 시 실행되는 함수
    function addMember() {
        const nameInput = document.getElementById('memberName');
        const daySelect = document.getElementById('memberDay');
        const slotSelect = document.getElementById('memberTimeSlot');

        const name = nameInput.value.trim();
        const day = daySelect.value;
        const timeText = slotSelect.options[slotSelect.selectedIndex].text;

        if (!name) {
            alert("부원의 이름을 입력해주세요!");
            return;
        }

        // 1. 데이터 배열에 추가
        const newEntry = { name, day, timeText };
        scheduleData.push(newEntry);

        // 2. 화면의 테이블 업데이트
        updateTable();

        // 3. 입력창 초기화
        nameInput.value = "";
    }

    // 테이블 화면을 새로고침하는 함수
    function updateTable() {
        const tbody = document.getElementById('memberList');
        tbody.innerHTML = ""; // 기존 내용 비우기

        scheduleData.forEach((m, index) => {
            const row = document.createElement('tr');
            row.innerHTML = `
                <td>${m.name}</td>
                <td>${m.day}요일</td>
                <td>${m.timeText}</td>
                <td><button onclick="removeMember(${index})" style="background: #ff4d4d; color:white; border:none; border-radius:4px; padding:5px 10px; cursor:pointer;">삭제</button></td>
            `;
            tbody.appendChild(row);
        });
    }

    // 삭제 기능
    function removeMember(index) {
        scheduleData.splice(index, 1);
        updateTable();
    }

    // 최적 시간 계산 기능
    function calculate() {
        if (scheduleData.length === 0) {
            alert("분석할 데이터가 없습니다. 먼저 추가해주세요!");
            return;
        }

        let counts = {};
        scheduleData.forEach(item => {
            let key = `${item.day}요일 ${item.timeText}`;
            counts[key] = (counts[key] || 0) + 1;
        });

        // 가장 많이 겹치는 시간 찾기
        let sorted = Object.entries(counts).sort((a, b) => b[1] - a[1]);
        let best = sorted[0];

        document.getElementById('result').innerHTML = `
            <strong>✨ 분석 결과:</strong> 가장 많은 부원이 모일 수 있는 시간은 <span style="color:#003366; font-size:1.2rem;">[${best[0]}]</span> 입니다!<br>
            (현재 참여 확정 인원: ${best[1]}명)
        `;
    }
</script>

</body>
</html>
